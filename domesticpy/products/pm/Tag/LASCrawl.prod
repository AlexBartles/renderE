import os
import twc.products
import twccommon
import twccommon.Log as Log


class Product(twc.products.Product):
    
    def _getDesiredDuration(self, minimum, maximum, optimal):
        params = self.getParams()
        if params.lasCrawlText != None:
            return optimal
            
        return 0

