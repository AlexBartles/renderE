
<prod>

<impl>

<![CDATA[
import radar
import os
import string
import twccommon
import twc.dsmarshal as dsm

class Product(radar.AnimatedMap):

    def __init__(self, params):
        radar.AnimatedMap.__init__(self, params)

        # set the max number of images that can be missing before the
        # animation loop is cancelled
        self._maxAllowedImageGap = 4   # image file count

        # assume this radar image has some rain until we determine otherwise
        self._radarReturns = 1

        data = self.getData() # get imageRoot

        # get any additional info about the map cut (in case we need it)
        mapDataString = data.productString + '.MapData'
        mapCutData = dsm.defaultedGet(mapDataString)

        dataCutType = mapCutData.datacutType
        dataCutInfo = dataCutType.split('.')
        
        self.updateData(
            # this is where the image data lives
            imageRoot = data.imageRoot +'/%s/%s.cuts/' % (dataCutInfo[0],
                        dataCutInfo[1]),

            # set the image data parameters
            imageFrequency     = 300, # seconds
            maxImages          =  36, # image file count
            imageDuration      =   4, # frame count
            lastImageDuration  =  40, # frame count
            mapLocation        = dataCutInfo[1]) # us, pr, ak, hi, etc.
            


    def _getDesiredDuration(self, minimum, maximum, optimal):
        data = self.getData()
        # if there's no data (or if there's no map cut), then
        # don't display this product
        if data.noDataAvailable:
            return 0

        return optimal


    def _getDesiredPageDurations(self, pageParams):
        raise Exception("Multipage support not enabled for this product")


    def _loadData(self):
        radar.AnimatedMap._loadData(self)
        params = self.getParams()
        data   = self.getData()

        # set the data not available text for this product
        data.noDataAvailableText = "Temporarily Unavailable"

        # check specifically for 'stats' files for this product
        if data.noDataAvailable:
            self._radarReturns = 0
        else:
            # does the most recent data image show significant amounts of rain?
            issuetime, newestImageDataFileName = data.imageList[0]
            fname, ftype = string.split(newestImageDataFileName, '.tif')
            statsFile = fname + '.data.stats'

            nsRain = {} # create private namespace
            if os.path.isfile(statsFile):
                execfile(statsFile, nsRain, nsRain)
                twccommon.Log.info("%s rainDensity = %d" %
                                  (params.product, nsRain['rainDensity'],))
            else:
                twccommon.Log.error("missing radar stats file %s" % statsFile)

            # try to get the rainDensity out of the stats file, but if something went
            # wrong, then assume that the radar image has significant rain echoes.
            if nsRain.has_key('rainDensity'):
                rainDensity = nsRain['rainDensity']
            else:
                msg = "Error reading stats file: %s. " % (statsFile,)
                msg += "Assuming rainDensity > 5 (echoes present)."
                twccommon.Log.warning(msg)

            if rainDensity < 5:
                self._radarReturns = 0
                twccommon.Log.info("no rain, so radarReturns set to 0")
            else:
                twccommon.Log.info("rain echoes found (rainDensity > 5), radarReturns set to 1")
                self._radarReturns = 1


    def hasReturns(self):
        return self._radarReturns

]]>
</impl>


