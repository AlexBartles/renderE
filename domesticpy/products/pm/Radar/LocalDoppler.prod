#                         (20,90,20,255),   # Dark Green
#                         (200,200,50,255), # Yellow
#                         (220,150,30,255), # Orange
#                         (186,0,32,255),   # Lightest Red
#                         (96,23,11,255) ]  # Darkest Red
    

#        xOffset = x + 4 # per art doc
#        width   = 7 # box width per art doc
#        height  = 9 # box height per art doc
#        conusAdjustment = -57

#        for color in legendColors:

            # actual boxes
#            bb = Box()
#            bb.setSize(width,height)
#            bb.setPosition(xOffset+conusAdjustment,y-1)
#            r,g,b,a = renderUtil.rgbaConvert(color[0], color[1], color[2], color[3])
#            bb.setColor(r,g,b,a)
#            p.addItem(bb)

#           xOffset += 7 # per art doc

    f = TTFont("/rsrc/fonts/Interstate-Bold", 12, t=10, shadow=0)
    r,g,b,a = renderUtil.rgbaConvert(229,229,229)
    # "cool" legend updates every 5 minutes until 1 hour
    # then every 30 mins until 3 hours (3 hours = max.)
    txt = calculateLegendText()
    t = Text(f, txt)
    xPos = renderUtil.justifyGR(t.size()[0], x, renderUtil.RIGHT)
    t.setPosition(xPos+conusAdjustment, y)
    t.setColor(r, g, b, a)
    p.addItem(t)


# Gradient Box
gradientColors = [ (18,137,180,255),
                   (8,121,157,255),
                 ]

# draw legend
# WARNING: The coordinates below are adjusted to account
# for the 'radar' viewport "shift" of -12, -12.

gBox = renderUtil.gradientBox(216,19,gradientColors)
gBox.setPosition(12,125) # (0,113) actual if viewport wasn't shifted
# draw the gBox, then the legend (draw order counts!)
p.addItem(gBox)

# draw it!
drawLegend(221,132, p) # (152,120) actual if viewport wasn't shifted

