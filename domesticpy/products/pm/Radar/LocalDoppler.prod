# MAP LEGEND:
def calculateLegendText():

    global imageCount, imageFrequency

    legendText = ''
    timeSpanSeconds  = float(imageCount) * float(imageFrequency)
    timeLapseMinutes = timeSpanSeconds / 60.0
    timeLapseHours   = timeSpanSeconds / 3600.0
    remainderSeconds = timeSpanSeconds % 3600.0

    # if it's less than an hour, show 'MINS'
    if timeSpanSeconds < 3600.0:
        legendText = 'PAST %0.0f MINS' % (timeLapseMinutes,)

    # Otherwise, show only whole hours or half-hours (per Product Team request)
    # so if it's less than 1.5 hours, show 'HOUR'
    # (above an hour, only update the legend every 1/2 hour)
    elif timeSpanSeconds < 5400.0:
        legendText = 'PAST %0.0f HOUR' % (timeLapseHours,)

    else: # we're over the 'hour' bracket now...

        if remainderSeconds < 1800.0:
            # below x.5 round down to x (no decimal place)
            legendText = 'PAST %0.0f HOURS' % (timeLapseHours,)
        else:
            # above x.5 round down to x.5
            delta = remainderSeconds - 1800.0
            nearestHalfHour = timeSpanSeconds - delta
            timeLapseHours  = nearestHalfHour / 3600.0
            legendText = 'PAST %0.1f HOURS' % (timeLapseHours,)

    return legendText

def drawLegend(x,y,p):

    conusAdjustment = 0

####################################################################################
# This block of code is commented out in case product changes their minds and
# wants the legend back for sqeezeback. 
####################################################################################
